# ===== 服务配置 =====
APP_NAME=campus_collab
APP_ENV=development          # development / staging / production
APP_PORT=8080
APP_HOST=0.0.0.0

# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=campus_collab
DB_USER=root
DB_PASSWORD=your_password_here
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100

# ===== JWT 配置 =====
JWT_SECRET=your-secret-key-change-in-production-32chars!!
JWT_EXPIRE_HOURS=24
JWT_REFRESH_HOURS=168

# ===== 加密密钥（用于学号、手机号加密）=====
ENCRYPT_KEY=your-32-byte-aes-key-change-me-now!!

# ===== Redis =====
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== 日志配置 =====
LOG_LEVEL=debug              # debug / info / warn / error
LOG_FORMAT=console           # json / console

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173
